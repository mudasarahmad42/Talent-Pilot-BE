{
  "ConnectionStrings": {
    "TalentPilot": ""
  },
  "DataAccess": {
    "IdentityProvider": "SqlServer"
  },
  "Auth": {
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Jwt": {
    "Issuer": "TalentPilot",
    "Audience": "TalentPilot.Web"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://127.0.0.1:4200"
    ]
  },
  "PublicFeedback": {
    "RecipientEmail": "mudasarahmad150@gmail.com",
    "SenderEmail": ""
  },
  "Security": {
    "Transport": {
      "EnableHttpsRedirection": false,
      "EnableHsts": false
    },
    "RateLimiting": {
      "Global": {
        "PermitLimit": 1200,
        "WindowSeconds": 60,
        "QueueLimit": 100
      },
      "Auth": {
        "PermitLimit": 60,
        "WindowSeconds": 60,
        "QueueLimit": 20
      },
      "AiWork": {
        "PermitLimit": 180,
        "WindowSeconds": 300,
        "QueueLimit": 25
      },
      "PublicPortal": {
        "PermitLimit": 600,
        "WindowSeconds": 60,
        "QueueLimit": 50
      }
    }
  },
  "TalentPilotRuntime": {
    "Provider": "Mock/Ollama",
    "LlmModel": "llama3.2:1b",
    "EmbeddingModel": "nomic-embed-text",
    "EmbeddingDimensions": 768,
    "VectorStore": "SqlServerVector",
    "OllamaBaseUrl": "http://localhost:11434"
  },
  "WebResearch": {
    "Provider": "Tavily"
  },
  "TavilySearch": {
    "Enabled": true,
    "BaseUrl": "https://api.tavily.com/search",
    "DailyRequestLimit": 60,
    "RequestTimeoutSeconds": 20,
    "SearchDepth": "basic"
  },
  "GoogleCalendar": {
    "Enabled": true,
    "ApplicationName": "Talent Pilot",
    "CalendarId": "primary",
    "DefaultTimeZoneId": "Asia/Karachi",
    "CreateGoogleMeetLink": true,
    "Scope": "https://www.googleapis.com/auth/calendar.events",
    "FrontendSuccessRedirectUrl": "/settings/integrations/google-calendar/success",
    "FrontendErrorRedirectUrl": "/settings/integrations/google-calendar/error"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
