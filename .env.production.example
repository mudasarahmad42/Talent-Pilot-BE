SA_PASSWORD=Tkxel123
ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production
OLLAMA_LLM_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
JWT_SIGNING_KEY=change-this-to-a-long-random-secret-at-least-32-characters

# Public host and HTTPS
APP_HOSTNAME=talentpilot-demo.duckdns.org
LETSENCRYPT_EMAIL=admin@example.com
# Bootstrap uses nginx.conf. After ./deploy/enable-https.sh succeeds this becomes nginx.https.conf.
NGINX_CONF=nginx.conf

# Email delivery
# The seeded tenant defaults to MicrosoftGraph. Keep real values only in .env.production.
PUBLIC_FEEDBACK_RECIPIENT_EMAIL=mudasarahmad150@gmail.com
# Optional override. Leave empty to use the selected provider sender.
PUBLIC_FEEDBACK_SENDER_EMAIL=

# Microsoft Graph email delivery
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_FROM_EMAIL=
MICROSOFT_GRAPH_SAVE_TO_SENT_ITEMS=true

# Optional Resend email delivery, only if the tenant provider is changed to Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Online headhunting search providers
# GitHub works without a token but a token improves rate limits.
GITHUB_SEARCH_ENABLED=true
GITHUB_TOKEN=

# Web search requires either Tavily or Google Custom Search credentials.
WEB_RESEARCH_PROVIDER=Tavily
TAVILY_SEARCH_ENABLED=true
TAVILY_API_KEY=
GOOGLE_SEARCH_ENABLED=false
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Google Calendar interview scheduling
# Enabled by default; set false only when intentionally disabling calendar events.
GOOGLE_CALENDAR_ENABLED=true
GOOGLE_CALENDAR_APPLICATION_NAME=Talent Pilot
GOOGLE_CALENDAR_CALENDAR_ID=primary
GOOGLE_CALENDAR_DEFAULT_TIME_ZONE_ID=Asia/Karachi
GOOGLE_CALENDAR_CREATE_MEET_LINK=true
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=https://talentpilot-demo.duckdns.org/api/google-calendar/oauth/callback
GOOGLE_CALENDAR_SCOPE=https://www.googleapis.com/auth/calendar.events
GOOGLE_CALENDAR_FRONTEND_SUCCESS_URL=/settings/integrations/google-calendar/success
GOOGLE_CALENDAR_FRONTEND_ERROR_URL=/settings/integrations/google-calendar/error
