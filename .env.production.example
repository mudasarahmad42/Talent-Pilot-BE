SA_PASSWORD=Tkxel123
ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production
OLLAMA_LLM_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
JWT_SIGNING_KEY=change-this-to-a-long-random-secret-at-least-32-characters

# Email delivery
# The seeded tenant defaults to Resend. Set a real Resend API key and a verified sender email,
# or switch the tenant provider to MicrosoftGraph in Admin Center and fill the Graph values below.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
PUBLIC_FEEDBACK_RECIPIENT_EMAIL=mudasarahmad150@gmail.com
# Optional override. Leave empty to use the selected provider sender.
PUBLIC_FEEDBACK_SENDER_EMAIL=

# Optional Microsoft Graph email delivery
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_FROM_EMAIL=
MICROSOFT_GRAPH_SAVE_TO_SENT_ITEMS=true
